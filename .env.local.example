# Google Places API — required to auto-fetch reviews at build time
# 1. Enable "Places API (New)" in Google Cloud Console
# 2. Create an API key restricted to the Places API and your domain
# 3. Find your Place ID at https://developers.google.com/maps/documentation/places/web-service/place-id
#    (search for "Classic Countertops LLC Akron Ohio")

GOOGLE_PLACES_API_KEY=your_api_key_here
GOOGLE_PLACE_ID=your_place_id_here
